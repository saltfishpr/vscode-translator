{
  "name": "vscode-translator",
  "displayName": "vscode-translator",
  "description": "Translate selected text using Google / DeepL / OpenAI / Baidu APIs",
  "version": "0.1.1",
  "publisher": "saltfishpr",
  "repository": {
    "type": "git",
    "url": "https://github.com/saltfishpr/vscode-translator"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "translator.translateSelection",
        "title": "Translate: Translate Selected Text"
      },
      {
        "command": "translator.translateAndReplace",
        "title": "Translate: Translate and Replace Selection"
      },
      {
        "command": "translator.pickProvider",
        "title": "Translate: Switch Provider"
      },
      {
        "command": "translator.pickTargetLang",
        "title": "Translate: Switch Target Language"
      }
    ],
    "keybindings": [
      {
        "command": "translator.translateSelection",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorHasSelection"
      },
      {
        "command": "translator.translateAndReplace",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Translator",
      "properties": {
        "translator.provider": {
          "type": "string",
          "enum": [
            "google",
            "deepl",
            "openai",
            "baidu"
          ],
          "default": "google",
          "description": "Translation provider"
        },
        "translator.targetLang": {
          "type": "string",
          "default": "zh-CN",
          "description": "Target language code (e.g. zh-CN, en, ja, fr)"
        },
        "translator.sourceLang": {
          "type": "string",
          "default": "auto",
          "description": "Source language code; 'auto' for auto-detect"
        },
        "translator.displayMode": {
          "type": "string",
          "enum": [
            "hover",
            "panel"
          ],
          "default": "hover",
          "description": "How to display translation result"
        },
        "translator.google.apiKey": {
          "type": "string",
          "default": "",
          "description": "Google Cloud Translation API key (leave empty to use free endpoint)"
        },
        "translator.deepl.apiKey": {
          "type": "string",
          "default": "",
          "description": "DeepL API key"
        },
        "translator.deepl.useFree": {
          "type": "boolean",
          "default": true,
          "description": "Use DeepL free API endpoint"
        },
        "translator.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI / compatible API key"
        },
        "translator.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible base URL"
        },
        "translator.openai.model": {
          "type": "string",
          "default": "gpt-5.4-mini",
          "description": "Model name for OpenAI translation"
        },
        "translator.baidu.appid": {
          "type": "string",
          "default": "",
          "description": "Baidu Translate APP ID"
        },
        "translator.baidu.secret": {
          "type": "string",
          "default": "",
          "description": "Baidu Translate secret"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}